@model eBank_Bo.Web.Models.TransactionHistoryViewModel
@{
    ViewData["Title"] = "Transaction History";
}

<h2>History for @Model.AccountNumber</h2>
<div class="alert alert-info">
    <strong>Current Balance:</strong> @Model.CurrentBalance.ToString("C")
</div>
<hr />

@if (!Model.Transactions.Any())
{
    <p>No transactions found for this account.</p>
}
else
{
    <table class="table table-striped table-hover">
        <thead>
            <tr>
                <th>Date</th>
                <th>Type</th>
                <th>Amount</th>
                <th>Description</th>
                <th>Balance After</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model.Transactions)
            {
                <tr>
                    <td>@item.Date.ToString("g")</td>
                    <td>
                        @if (item.Type == "Deposit")
                        {
                            <span class="badge bg-success">@item.Type</span>
                        }
                        else
                        {
                            <span class="badge bg-warning text-dark">@item.Type</span>
                        }
                    </td>
                    <td>@item.Amount.ToString("C")</td>
                    <td>@item.Description</td>
                    <td>@item.BalanceAfter.ToString("C")</td>
                </tr>
            }
        </tbody>
    </table>
}

<div class="mt-3">
    <a asp-controller="Account" asp-action="Index" class="btn btn-outline-primary">Back to Accounts</a>
</div>
