@model eBank_Bo.Web.Models.DepositViewModel
@{
    ViewData["Title"] = "Deposit";
}

<h2>Deposit to @Model.AccountNumber</h2>
<hr />

<div class="row">
    <div class="col-md-6">
        <div class="alert alert-info">
            <strong>Current Balance:</strong> @Model.CurrentBalance.ToString("C")
        </div>

        <form asp-action="Deposit" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="AccountId" />
            
            <div class="form-group mb-3">
                <label asp-for="Amount" class="control-label"></label>
                <input asp-for="Amount" class="form-control" type="number" step="0.01" min="0.01" />
                <span asp-validation-for="Amount" class="text-danger"></span>
            </div>
            
            <div class="form-group">
                <input type="submit" value="Process Deposit" class="btn btn-success" />
                <a asp-controller="Account" asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
