@model eBank_Bo.Data.Models.Account
@{
    ViewData["Title"] = "Account Details";
}

<h2>Account Details</h2>
<hr />

<div class="card" style="width: 24rem;">
    <div class="card-body">
        <h5 class="card-title">@Model.AccountNumber</h5>
        <h6 class="card-subtitle mb-2 text-muted">@Model.AccountType Account</h6>
        <p class="card-text">
            <strong>Customer:</strong> @Model.Customer?.FirstName @Model.Customer?.LastName<br />
            <strong>Current Balance:</strong> <span class="fs-4 text-success">@Model.Balance.ToString("C")</span>
        </p>
        
        <div class="mt-4">
            <a asp-controller="Transaction" asp-action="Deposit" asp-route-accountId="@Model.AccountId" class="btn btn-success">Deposit</a>
            <a asp-controller="Transaction" asp-action="Withdraw" asp-route-accountId="@Model.AccountId" class="btn btn-warning">Withdraw</a>
            <a asp-controller="Transaction" asp-action="History" asp-route-accountId="@Model.AccountId" class="btn btn-secondary">History</a>
        </div>
    </div>
</div>

<div class="mt-3">
    <a asp-action="Index" class="btn btn-outline-primary">Back to List</a>
</div>
